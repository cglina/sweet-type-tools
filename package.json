{
    "name": "sweet-type-tools",
    "version": "0.1.0",
    "description": "A library that combines TypeScript and runtime checks for easier and safer JS coding.",
    "keywords": [
        "sweet",
        "tools",
        "js",
        "javascript",
        "typescript",
        "utilities",
        "helpers",
        "array",
        "string",
        "number",
        "object",
        "data"
    ],
    "homepage": "https://github.com/cglina/sweet-type-tools#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cglina/sweet-type-tools.git"
    },
    "license": "MIT",
    "author": "Carolina Goetz",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "check": "tsc --noEmit"
    },
    "devDependencies": {
        "typescript": "5.8 - 6.0"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    }
}
